<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- RimWorld 1.6+: mechs use mechEnabledWorkTypes, not workEnabled -->
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>fyarn.PriorityClean</li>
    </mods>
    <match Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[race/mechEnabledWorkTypes/li[.='Cleaning']]/race/mechEnabledWorkTypes</xpath>
      <value>
        <li>PriorityCleaning</li>
      </value>
    </match>
  </Operation>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>fyarn.PriorityClean</li>
    </mods>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/ThingDef[race/mechEnabledWorkTypes/li[.='Cleaning']]/race/mechEnabledWorkTypes/li[.='PriorityCleaning'][preceding-sibling::li[.='PriorityCleaning']]</xpath>
    </match>
  </Operation>

  <!-- Legacy fallback for mods that still expose workEnabled -->
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>fyarn.PriorityClean</li>
    </mods>
    <match Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[race/workEnabled/li[.='Cleaning']]/race/workEnabled</xpath>
      <value>
        <li>PriorityCleaning</li>
      </value>
    </match>
  </Operation>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>fyarn.PriorityClean</li>
    </mods>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/ThingDef[race/workEnabled/li[.='Cleaning']]/race/workEnabled/li[.='PriorityCleaning'][preceding-sibling::li[.='PriorityCleaning']]</xpath>
    </match>
  </Operation>

  <!-- Route PriorityClean workgiver to compatibility subclass that also allows colony mechs -->
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>fyarn.PriorityClean</li>
    </mods>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/WorkGiverDef[defName='PriorityCleanFilth' or defName='PriorityClean']/giverClass</xpath>
      <value>
        <giverClass>Gadolinium.PriorityClean.UniversalPatch.WorkGiver_PriorityClean_Universal</giverClass>
      </value>
    </match>
  </Operation>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>fyarn.PriorityClean</li>
    </mods>
    <match Class="PatchOperationAdd">
      <xpath>/Defs/WorkGiverDef[(defName='PriorityCleanFilth' or defName='PriorityClean') and not(giverClass)]</xpath>
      <value>
        <giverClass>Gadolinium.PriorityClean.UniversalPatch.WorkGiver_PriorityClean_Universal</giverClass>
      </value>
    </match>
  </Operation>
</Patch>
